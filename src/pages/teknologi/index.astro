---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPosts = await getCollection('teknologi');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout title="Teknologi">
  <h1 class="text-3xl font-serif font-bold text-center mb-10 text-stone-900">Teknologi</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {sortedPosts.map((post) => (
      <a href={`/teknologi/${post.id}`} class="bg-white/30 backdrop-blur-md border border-white/50 rounded-xl overflow-hidden shadow-sm hover:shadow-lg hover:bg-white/50 transition-all duration-300 group">
        
        {/* Thumbnail Section */}
        <div class="h-48 w-full overflow-hidden">
          {post.data.image ? (
            <Image 
              src={post.data.image} 
              alt={post.data.title} 
              width={400} 
              height={200} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
            />
          ) : (
            <div class="w-full h-full bg-stone-200 flex items-center justify-center text-stone-400">?</div>
          )}
        </div>

        {/* Content Section */}
        <div class="p-5">
          <h2 class="text-lg font-bold text-stone-800 mb-2 line-clamp-2 group-hover:text-primary transition-colors">
            {post.data.title}
          </h2>
          <p class="text-stone-600 text-sm line-clamp-2 mb-4">
            {post.data.description}
          </p>
          <span class="text-xs text-stone-400 font-medium tracking-wide">
            {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
        </div>
      </a>
    ))}
  </div>
</MainLayout>