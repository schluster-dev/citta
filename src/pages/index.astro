---
import MainLayout from '../layouts/MainLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const asn = await getCollection('info-asn');
const pendidikan = await getCollection('pendidikan');
const teknologi = await getCollection('teknologi');

const allPosts = [...asn, ...pendidikan, ...teknologi].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = allPosts.slice(0, 3);
---

<MainLayout title="Beranda">
  <div class="min-h-screen bg-gradient-to-b from-stone-50 to-stone-200">
    
    <header class="text-center py-8 px-4">
      <h1 class="text-5xl md:text-7xl font-serif font-medium text-stone-900 mb-6">
        Citta <span class="text-primary italic">Indonesia</span>.
      </h1>
      
      <p class="text-stone-600 max-w-lg mx-auto text-lg mb-8">Platform Citta menyajikan update ASN, Teknologi, dan Pendidikan dengan estetika yang menenangkan.</p>
      
      <div class="overflow-hidden max-w-xl mx-auto h-8">
         <div id="live-ticker" class="text-stone-500 font-serif italic text-lg whitespace-nowrap animate-marquee">
          </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 px-4 sm:px-6 lg:px-8 pb-20">
      
      <div class="md:col-span-2 space-y-12">
        
        <section class="relative group">
          <h2 class="text-xl font-serif font-bold text-stone-800 mb-6 border-b border-stone-300 pb-2">Unggulan</h2>
          
          <button id="prevBtn" class="absolute left-2 top-[40%] z-20 bg-white/50 hover:bg-white p-2 rounded-full shadow backdrop-blur transition opacity-0 group-hover:opacity-100">❮</button>
          <button id="nextBtn" class="absolute right-2 top-[40%] z-20 bg-white/50 hover:bg-white p-2 rounded-full shadow backdrop-blur transition opacity-0 group-hover:opacity-100">❯</button>

          <div id="carousel" class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-4 scrollbar-hide scroll-smooth">
            {featuredPosts.map((post, index) => (
              <a href={`/${post.collection}/${post.id}`} 
                 data-index={index}
                 class="slide-item flex-none w-full snap-center relative rounded-2xl overflow-hidden shadow-lg group block h-[300px]">
                {post.data.image ? (
                  <Image src={post.data.image} alt={post.data.title} width={800} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                ) : (
                  <div class="w-full h-full bg-stone-200 flex items-center justify-center text-stone-400">Tidak ada gambar</div>
                )}
                <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-stone-900/90 to-transparent text-white">
                  <span class="text-xs uppercase tracking-widest font-bold text-primary mb-1 block">{post.collection}</span>
                  <h3 class="text-2xl font-serif font-bold">{post.data.title}</h3>
                </div>
              </a>
            ))}
          </div>

          <div id="dots" class="flex justify-center gap-2 mt-4">
            {featuredPosts.map((_, index) => (
              <button class="dot w-3 h-3 rounded-full bg-stone-300 transition-all duration-300 cursor-pointer" data-index={index}></button>
            ))}
          </div>
        </section>

        <section>
          <h2 class="text-xl font-serif font-bold text-stone-800 mb-6 border-b border-stone-300 pb-2">Berita Terbaru</h2>
          
          {/* Perubahan grid di sini: 2 kolom mobile, 3 kolom desktop */}
          <div id="news-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
            {allPosts.map((post) => (
               <a href={`/${post.collection}/${post.id}`} class="news-card block bg-white/30 backdrop-blur-md border border-white/50 rounded-xl shadow-sm hover:bg-white/40 transition-all overflow-hidden group">
                  <div class="h-24 md:h-40 w-full overflow-hidden">
                    {post.data.image ? (
                        <Image src={post.data.image} alt={post.data.title} width={400} height={200} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                    ) : (
                        <div class="w-full h-full bg-stone-200 flex items-center justify-center text-stone-400">?</div>
                    )}
                 </div>
                 <div class="p-3 md:p-4">
                    <span class="hidden md:block text-xs uppercase tracking-widest font-bold text-primary mb-2">{post.collection}</span>
                    <h2 class="text-sm md:text-lg font-bold mb-1 text-stone-800 line-clamp-2">{post.data.title}</h2>
                    <p class="hidden md:block text-stone-600 line-clamp-2 text-xs">{post.data.description}</p>
                 </div>
               </a>
            ))}
          </div>

          <div id="pagination-controls" class="flex justify-center gap-2 mt-8"></div>
        </section>
      </div>
      <aside class="md:col-span-1">
        <div class="sticky top-24 space-y-8">
            <div class="bg-white/30 backdrop-blur-md border border-white/50 p-6 rounded-xl">
              <h3 class="font-bold text-stone-800 mb-4">Kategori</h3>
              <ul class="space-y-2 text-stone-600">
                <li><a href="/info-asn" class="hover:text-primary">Info ASN</a></li>
                <li><a href="/pendidikan" class="hover:text-primary">Pendidikan</a></li>
                <li><a href="/teknologi" class="hover:text-primary">Teknologi</a></li>
              </ul>
            </div>
            <AdSlot className="h-[400px]" />
        </div>
      </aside>
    </div>
  </div>
</MainLayout>

<style is:global>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  @keyframes marquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
  .animate-marquee { animation: marquee 15s linear infinite; }
</style>

<script>
  // 1. Pagination Logika
  const cards = document.querySelectorAll('.news-card');
  const itemsPerPage = 6; // Diubah ke 6 sesuai permintaan
  const totalPages = Math.ceil(cards.length / itemsPerPage);
  const container = document.getElementById('pagination-controls');

  function showPage(page) {
    cards.forEach((card, index) => {
      if (index >= (page - 1) * itemsPerPage && index < page * itemsPerPage) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });

    // Update tombol aktif
    document.querySelectorAll('.page-btn').forEach(btn => {
      btn.classList.remove('bg-stone-800', 'text-white');
      btn.classList.add('bg-white', 'text-stone-800');
      if (parseInt(btn.getAttribute('data-page') || '1') === page) {
        btn.classList.add('bg-stone-800', 'text-white');
        btn.classList.remove('bg-white', 'text-stone-800');
      }
    });
  }

  // Create buttons
  if (totalPages > 1) {
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.textContent = i.toString();
      btn.className = 'page-btn px-4 py-2 rounded-lg border border-stone-300 transition-all';
      btn.setAttribute('data-page', i.toString());
      btn.addEventListener('click', () => {
          showPage(i);
          window.scrollTo({ top: (document.getElementById('news-grid')?.offsetTop || 0) - 100, behavior: 'smooth' });
      });
      container?.appendChild(btn);
    }
    // Init page 1
    showPage(1);
  }

  // 2. Ticker & Slider
  function updateTicker() {
    const ticker = document.getElementById('live-ticker');
    if (!ticker) return;
    const now = new Date();
    const time = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const date = now.toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    ticker.textContent = `${time} | ${date} | #Citta #Indonesia #ASN #Teknologi #Pendidikan`;
  }
  setInterval(updateTicker, 1000);
  updateTicker();

  const carousel = document.getElementById('carousel');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const dots = document.querySelectorAll('.dot');
  const slides = document.querySelectorAll('.slide-item');
  
  const updateDots = (activeIndex) => {
    dots.forEach((dot, i) => {
      if (i === activeIndex) {
        dot.classList.add('bg-stone-800', 'scale-110');
        dot.classList.remove('bg-stone-300');
      } else {
        dot.classList.remove('bg-stone-800', 'scale-110');
        dot.classList.add('bg-stone-300');
      }
    });
  };

  nextBtn?.addEventListener('click', () => carousel?.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' }));
  prevBtn?.addEventListener('click', () => carousel?.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' }));
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) updateDots(parseInt(entry.target.getAttribute('data-index') || '0')); });
  }, { threshold: 0.6 });
  
  slides.forEach(slide => observer.observe(slide));
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => carousel?.scrollTo({ left: (carousel.clientWidth * i), behavior: 'smooth' }));
  });
</script>