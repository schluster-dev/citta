---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import SocialSidebar from '../../components/SocialSidebar.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('pendidikan');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post) return Astro.redirect('/404');

const { Content } = await render(post);

// Logika untuk Post Terkait & Artikel Terbaru
const allPosts = await getCollection('pendidikan');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.tags?.some(tag => post.data.tags?.includes(tag)))
  .slice(0, 3);

const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<MainLayout title={post.data.title}>
  <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 lg:grid-cols-[1fr_300px] xl:grid-cols-[80px_1fr_300px] gap-8">
    
    <div class="hidden xl:block relative">
      <div class="sticky top-24 flex flex-col items-center">
        <SocialSidebar orientation="col" />
      </div>
    </div>

    <article class="min-w-0">
      <header class="mb-10 text-center">
        <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
        <p class="text-gray-500">
          Oleh {post.data.author || 'Admin'} pada {new Date(post.data.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </header>

      {post.data.image && (
        <figure class="mb-8">
          <Image 
            src={post.data.image} 
            alt={post.data.title} 
            class="w-full h-auto rounded-lg shadow-lg" 
            width={800} 
            height={400} 
          />
          {post.data.caption && (
            <figcaption class="text-xs text-stone-500 italic mt-2 text-center leading-snug">
              {post.data.caption}
            </figcaption>
          )}
        </figure>
      )}

      <div class="prose prose-stone prose-lg max-w-none text-justify leading-loose article-content">
        <Content />
      </div>

      <div class="xl:hidden mt-12 pt-6 border-t border-stone-200">
        <div class="flex justify-center">
          <SocialSidebar orientation="row" />
        </div>
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-12 pt-6 border-t border-stone-200">
          <h3 class="text-sm font-semibold text-stone-500 mb-3">Tags:</h3>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <span class="bg-stone-100 text-stone-700 px-3 py-1 rounded-full text-sm">#{tag}</span>
            ))}
          </div>
        </div>
      )}

      {relatedPosts.length > 0 && (
        <div class="mt-12 pt-6 border-t border-stone-200">
          <h3 class="text-xl font-bold mb-6">Post Terkait</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map(related => (
              <a href={`/pendidikan/${related.id}`} class="block group">
                {related.data.image && (
                  <div class="overflow-hidden rounded-lg mb-3">
                    <Image 
                      src={related.data.image} 
                      alt={related.data.title} 
                      width={400} 
                      height={200} 
                      class="w-full h-40 object-cover transition-transform duration-300 group-hover:scale-105" 
                    />
                  </div>
                )}
                <h4 class="font-bold text-lg mb-1 group-hover:text-blue-600 transition-colors">{related.data.title}</h4>
                <p class="text-sm text-stone-500 line-clamp-2">{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>

    <aside class="w-full">
      <div class="lg:sticky lg:top-24 space-y-8">
        <div class="bg-stone-50 p-6 rounded-xl border border-stone-200">
          <h3 class="font-bold text-stone-800 mb-4 border-b pb-2">Artikel Terbaru</h3>
          <ul class="space-y-4">
            {latestPosts.map(p => (
              <li>
                <a href={`/pendidikan/${p.id}`} class="block group">
                  <h4 class="text-sm font-semibold text-stone-700 group-hover:text-blue-600 transition-colors">{p.data.title}</h4>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </aside>

  </div>

  <style>
    .prose :global(p) { margin-bottom: 2rem !important; }
  </style>
</MainLayout>