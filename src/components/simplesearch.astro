---
// Ambil data posts yang dikirim dari index.astro
const { posts } = Astro.props;
---

<div class="relative w-full">
  <input 
    type="text" 
    id="search-input" 
    placeholder="Cari info..." 
    class="w-full px-4 py-2 border border-stone-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-stone-400 bg-white"
  />
  <ul id="results-list" class="absolute z-50 w-full mt-2 bg-white border border-stone-200 rounded-lg shadow-xl hidden overflow-hidden">
    </ul>
</div>

<script is:inline define:vars={{ posts }}>
  const input = document.getElementById('search-input');
  const list = document.getElementById('results-list');

  input.addEventListener('input', (e) => {
    const value = e.target.value.toLowerCase();
    
    if (value.length < 2) {
      list.classList.add('hidden');
      return;
    }

    const filtered = posts.filter(p => 
      p.data.title.toLowerCase().includes(value)
    );

    if (filtered.length > 0) {
      list.classList.remove('hidden');
      list.innerHTML = filtered.map(p => `
        <li class="px-4 py-2 border-b last:border-0 hover:bg-stone-50">
          <a href="/${p.collection}/${p.id}" class="block text-sm text-stone-800 font-medium">
            ${p.data.title}
          </a>
        </li>
      `).join('');
    } else {
      list.innerHTML = '<li class="px-4 py-2 text-stone-400 text-sm italic">Tidak ditemukan</li>';
      list.classList.remove('hidden');
    }
  });

  // Klik di luar untuk menutup
  document.addEventListener('click', (e) => {
    if (!input.contains(e.target)) list.classList.add('hidden');
  });
</script>