---
// src/components/Footer.astro
const menuItems = [
  { name: 'Tentang Kami', href: '/tentang-kami' },
  { name: 'Redaksi', href: '/redaksi' },
  { name: 'Info Iklan', href: '/info-iklan' },
  { name: 'Karir', href: '/karir' },
  { name: 'Kontak', href: '/kontak' },
  { name: 'Pedoman Media Siber', href: '/pedoman-media-siber' },
  { name: 'Pedoman AI', href: '/pedoman-ai' },
  { name: 'Privacy', href: '/privacy' },
];
---

<footer class="w-full py-8 mt-12 border-t border-stone-200">
  <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-sm text-stone-500">
    {menuItems.map((item, index) => (
      <div class="flex items-center gap-4">
        <a href={item.href} class="hover:text-stone-800 transition-colors">
          {item.name}
        </a>
        {/* Hanya tampilkan garis | jika bukan item terakhir */}
        {index < menuItems.length - 1 && <span class="text-stone-300 select-none">|</span>}
      </div>
    ))}
  </div>
  <p class="text-center text-xs text-stone-400 mt-4">
    © {new Date().getFullYear()} Citta. All rights reserved.
  </p>
</footer>