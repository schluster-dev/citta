---
// src/components/Header.astro
const { pathname } = Astro.props;
const isActive = (path: string) => pathname === path || (path !== '/' && pathname.startsWith(path));

// Menggunakan Lucide Icons (Gratis & Open Source)
const socialLinks = [
  { name: 'Instagram', url: 'https://instagram.com/citta', svg: '<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/><path d="m17.5 6.5-1 1-1-1"/><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12s4.5 10 10 10h10z"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>' },
  { name: 'X', url: 'https://x.com/citta', svg: '<path d="M4 4l11.733 16h4.533L8.533 4z"/><path d="M4 20l6.763-6.335M17.657 4l-6.286 5.89"/>' },
  { name: 'Facebook', url: 'https://facebook.com/citta', svg: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>' },
  { name: 'YouTube', url: 'https://youtube.com/@citta', svg: '<path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1-1 29 29 0 0 1 16.5 0 2 2 0 0 1 1 1 24.12 24.12 0 0 1 0 10 2 2 0 0 1-1 1 29 29 0 0 1-16.5 0 2 2 0 0 1-1-1z"/><path d="m10 15 5-3-5-3z"/>' },
  { name: 'TikTok', url: 'https://tiktok.com/@citta', svg: '<path d="M9 12a4 4 0 1 0 4 4V4a4 4 0 0 0-4 4"/>' },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-stone-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
    
    <div class="flex items-center">
      <a href="/" class="text-xl font-bold tracking-tighter text-stone-900 hover:text-stone-600 transition">CITTA</a>
      <div class="h-5 w-[1px] bg-stone-300 mx-4"></div>
    </div>

    <button id="menu-toggle" class="md:hidden p-2 text-stone-600">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>

    <div class="hidden md:flex items-center gap-6 text-xs font-medium uppercase tracking-widest text-stone-600">
      <a href="/info-asn" class={`transition hover:text-stone-900 ${isActive('/info-asn') ? 'text-stone-950 font-bold' : ''}`}>Info ASN</a>
      <a href="/pendidikan" class={`transition hover:text-stone-900 ${isActive('/pendidikan') ? 'text-stone-950 font-bold' : ''}`}>Pendidikan</a>
      <a href="/teknologi" class={`transition hover:text-stone-900 ${isActive('/teknologi') ? 'text-stone-950 font-bold' : ''}`}>Teknologi</a>
      
      <div class="flex items-center gap-4 border-l border-stone-200 pl-6 text-stone-400">
        {socialLinks.map(link => (
          <a href={link.url} target="_blank" class="hover:text-stone-900 transition" aria-label={link.name}>
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={link.svg} />
          </a>
        ))}
      </div>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-stone-100 px-4 py-4 space-y-4">
    <a href="/info-asn" class="block text-xs font-medium uppercase tracking-widest text-stone-600">Info ASN</a>
    <a href="/pendidikan" class="block text-xs font-medium uppercase tracking-widest text-stone-600">Pendidikan</a>
    <a href="/teknologi" class="block text-xs font-medium uppercase tracking-widest text-stone-600">Teknologi</a>
    <div class="pt-4 border-t border-stone-100 flex gap-5 text-stone-400">
        {socialLinks.map(link => (
          <a href={link.url} target="_blank" aria-label={link.name}>
             <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={link.svg} />
          </a>
        ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>