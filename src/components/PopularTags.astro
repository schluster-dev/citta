---
import { getCollection } from 'astro:content';

// 1. Ambil semua post dari semua koleksi
const allPosts = [
  ...await getCollection('info-asn'),
  ...await getCollection('pendidikan'),
  ...await getCollection('teknologi')
];

// 2. Hitung frekuensi tag
const tagCounts: Record<string, number> = {};

allPosts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

// 3. Ubah jadi array, urutkan berdasarkan jumlah terbanyak, ambil 10 teratas
const popularTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 10);
---

<div class="bg-white/30 backdrop-blur-md border border-white/50 p-6 rounded-xl">
  <h3 class="font-bold text-stone-800 mb-4 border-b border-stone-200 pb-2">Tag Populer</h3>
  <div class="flex flex-wrap gap-2">
    {popularTags.map(([tag, count]) => (
      <a 
        href={`/tags/${tag}`} 
        class="bg-stone-200 hover:bg-stone-300 text-stone-700 hover:text-stone-900 px-3 py-1 rounded-full text-xs transition-colors duration-200 font-medium"
      >
        {tag} <span class="opacity-60 font-normal">({count})</span>
      </a>
    ))}
  </div>
</div>