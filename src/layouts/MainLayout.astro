---
// Import SEO
import SEO from '../components/SEO.astro';

// Tambahkan props agar Layout bisa menerima data dari halaman
interface Props {
  title?: string;
  description?: string;
  publishDate?: string;
}

const { title, description, publishDate } = Astro.props;

import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pathname = Astro.url.pathname;
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <SEO 
      title={title ? `${title} | Citta` : 'Citta'} 
      description={description || 'Selamat datang di Citta, tempat berbagi cerita dan inspirasi.'} 
      publishDate={publishDate}
    />
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans leading-relaxed">
    
    <Header pathname={pathname} />
    
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-[70vh] text-justify">
      <slot />
    </main>

    <Footer />

    <SpeedInsights />
  </body>
</html>