---
const { title } = Astro.props;
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';

const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname === path || (path !== '/' && pathname.startsWith(path));
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | Citta` : 'Citta'}</title>
  </head>
  <body class="bg-stone-50 text-stone-800 font-sans leading-relaxed">
    
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-stone-200">
      {/* max-w-7xl memberikan ruang lebih lebar */}
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap justify-between items-center gap-4">
        
        <a href="/" class="text-2xl font-bold tracking-tighter text-stone-900 hover:opacity-75 transition">
          CITTA
        </a>

        <div class="flex items-center gap-4 sm:gap-6 text-xs sm:text-sm font-medium uppercase tracking-widest text-stone-600">
          <a href="/info-asn" class={`transition hover:text-stone-900 ${isActive('/info-asn') ? 'text-stone-950 font-bold' : ''}`}> Info ASN</a>
          <a href="/pendidikan" class={`transition hover:text-stone-900 ${isActive('/pendidikan') ? 'text-stone-950 font-bold' : ''}`}>Pendidikan</a>
          <a href="/teknologi" class={`transition hover:text-stone-900 ${isActive('/teknologi') ? 'text-stone-950 font-bold' : ''}`}>Teknologi</a>
        </div>
      </div>
    </nav>
    
    {/* Menggunakan max-w-7xl agar konten utama ikut melebar */}
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 min-h-[70vh]">
      <slot />
    </main>

    <footer class="border-t border-stone-200 mt-10">
      <div class="max-w-7xl mx-auto px-6 py-8 text-center text-stone-500 text-xs">
        &copy; {new Date().getFullYear()} Citta. Platform Informasi Kreatif.
      </div>
    </footer>

    <SpeedInsights />
  </body>
</html>